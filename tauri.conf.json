{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glitch Goblin",
  "version": "0.2.11-alpha.1",
  "identifier": "com.glitch-goblin.dev",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Glitch Goblin",
        "decorations": false,
        "dragDropEnabled": false,
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4RjNFRDg5OUYxOUE0QzEKUldUQnBCbWZpZTN6R0g4aVRDRlhuMy9HZ0tkMXo1L0pWVVAyVlV2Tkx6N0htampzNzcrRXFNMHoK",
      "endpoints": [
        "https://github.com/breiti35/Glitch-Goblin/releases/latest/download/latest.json"
      ]
    }
  }
}
